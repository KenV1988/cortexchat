# Copy to .env and fill in what you have. cortexchat works with zero keys
# (local Ollama only) and gets progressively more capable as you add more.

# --- Cloud providers (all optional) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# --- Local inference (recommended, free, private) ---
# Point at a running Ollama instance. Default assumes localhost.
OLLAMA_BASE_URL=http://localhost:11434

# --- Embeddings for semantic memory (optional) ---
# If unset, cortexchat tries Ollama first, then OpenAI if a key is present,
# then disables semantic memory and runs in degraded (working-memory-only) mode.
EMBEDDING_PROVIDER=auto

# --- Database ---
DATABASE_PATH=./data/cortexchat.sqlite

# --- Web app ---
SESSION_SECRET=change-me-to-a-random-string
PORT=3000
