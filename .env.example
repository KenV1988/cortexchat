# Copy to .env. cortexchat is 100% free by default:
#   - with Ollama running locally you need NOTHING here at all
#   - add a free OpenRouter key (no payment method required) to unlock the
#     bigger free open-source cloud models for hard questions

# --- Free open-source cloud models (recommended) ---
# Create a free account and key at https://openrouter.ai/keys — the default
# model registry only uses OpenRouter's ":free" models, which cost $0.
OPENROUTER_API_KEY=

# --- Local inference (free, private, offline) ---
# Point at a running Ollama instance. Default assumes localhost.
OLLAMA_BASE_URL=http://localhost:11434

# --- Paid providers (OPTIONAL — not used by the default registry) ---
# The adapters support OpenAI/Anthropic for anyone who wants them; you would
# also need to add their models to config/models.yaml. Leave empty for a
# fully free setup.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Embeddings for semantic memory (optional) ---
# "auto" tries Ollama first (free — `ollama pull nomic-embed-text`), then
# OpenAI if a key is present, then falls back to free keyword-only memory.
EMBEDDING_PROVIDER=auto

# --- Database ---
DATABASE_PATH=./data/cortexchat.sqlite

# --- Web app ---
SESSION_SECRET=change-me-to-a-random-string
PORT=3000
